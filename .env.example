# ─────────────────────────────────────────────────────────────
# financial-news-analytics — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get a free key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Optional — defaults shown ─────────────────────────────────

# Comma-separated list of tickers to track
# TICKERS=AAPL,TSLA,NVDA,MSFT,AMZN

# How many days back to fetch news
# Free tier supports up to 1 year of history via company-news endpoint
# NEWS_LOOKBACK_DAYS=7

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ── Phase 2: FinBERT Sentiment Analysis ───────────────────────

# Hugging Face model identifier (downloaded and cached on first run)
# FINBERT_MODEL=ProsusAI/finbert

# Inference batch size — increase for GPU, decrease for low-memory CPU
# FINBERT_BATCH_SIZE=32

# Compute device: auto | cpu | cuda | mps
# 'auto' selects CUDA → Apple MPS → CPU in that order
# FINBERT_DEVICE=auto
